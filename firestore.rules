rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES DE SEGURANÇA ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário logado é um Super Administrador do sistema
    function isSuperAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'super_admin';
    }

    function getRole() {
      return request.auth.token.role;
    }

    function isMemberOf(establishmentId) {
      return isSignedIn() && (
        isSuperAdmin() || 
        request.auth.token.establishmentId == establishmentId || 
        get(/databases/$(database)/documents/establishments/$(establishmentId)).data.ownerId == request.auth.uid
      );
    }

    function isOwner(establishmentId) {
      return isSuperAdmin() || (isMemberOf(establishmentId) && getRole() == 'owner');
    }

    function isNotChangingSensitiveFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'permissions', 'establishmentId', 'subscription']);
    }

    // --- COLEÇÕES DO SISTEMA (KAIROS CORE) ---

    // Permite que admins loguem e usuários consultem seu próprio perfil de acesso
    match /admin_users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow write: if isSuperAdmin();
    }

    // Gerenciamento de Planos/Pacotes
    match /packages/{packageId} {
      allow read: if true; // Público para o registro, mas escrita só Super Admin
      allow write: if isSuperAdmin();
    }

    // --- COLEÇÕES DE CLIENTES (TENANTS) ---

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isMemberOf(resource.data.establishmentId));
      allow create: if isSignedIn() && (isMemberOf(request.resource.data.establishmentId) && getRole() == 'owner') || isSuperAdmin();
      allow delete: if isSignedIn() && (isMemberOf(resource.data.establishmentId) && getRole() == 'owner') || isSuperAdmin();
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && isNotChangingSensitiveFields()) || 
        (isMemberOf(resource.data.establishmentId) && getRole() == 'owner') ||
        isSuperAdmin()
      );
    }

    match /establishments/{establishmentId} {
      allow get: if true; 
      allow list, create, delete: if isSuperAdmin();
      allow update: if isOwner(establishmentId) 
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscription']) || isSuperAdmin());

      match /notifications/{notificationId} {
        allow read: if isMemberOf(establishmentId);
        allow write: if isSuperAdmin(); 
      }
    }

    // --- COLEÇÕES DE NEGÓCIO ---

    match /suppliers/{supplierId} {
      allow read, write: if isSignedIn() && isMemberOf(request.resource.data.establishmentId || resource.data.establishmentId);
    }

    match /purchases/{purchaseId} {
      allow read, write: if isSignedIn() && isMemberOf(request.resource.data.establishmentId || resource.data.establishmentId);
    }

    match /clients/{clientId} {
      allow read, write: if isSignedIn() && isMemberOf(request.resource.data.establishmentId || resource.data.establishmentId);
      
      match /loyaltyHistory/{historyId} {
        allow read, create: if isSignedIn() && isMemberOf(get(/databases/$(database)/documents/clients/$(clientId)).data.establishmentId);
      }
    }

    match /appointments/{appointmentId} {
      allow create: if true; 
      allow read, update, delete: if isSignedIn() && isMemberOf(resource.data.establishmentId);
    }

    match /products/{productId} {
      allow read, write: if isSignedIn() && isMemberOf(request.resource.data.establishmentId || resource.data.establishmentId);

      match /stockHistory/{historyId} {
        allow read: if isSignedIn() && isMemberOf(get(/databases/$(database)/documents/products/$(productId)).data.establishmentId);
        allow create: if isSignedIn() && isMemberOf(request.resource.data.establishmentId);
      }
    }
    
    match /productCategories/{categoryId} {
      allow read, write: if isSignedIn() && isMemberOf(request.resource.data.establishmentId || resource.data.establishmentId);
    }

    match /sales/{saleId} {
       allow read, write: if isSignedIn() && isMemberOf(request.resource.data.establishmentId || resource.data.establishmentId);
    }
    
    match /blockages/{blockageId} {
      allow read, write: if isSignedIn() && isMemberOf(request.resource.data.establishmentId || resource.data.establishmentId);
    }
    
    match /cashierSessions/{sessionId} {
      allow read, write: if isSignedIn() && isMemberOf(request.resource.data.establishmentId || resource.data.establishmentId);
    }

    match /services/{serviceId} {
      allow get, list: if true;
      allow write: if isSignedIn() && isMemberOf(request.resource.data.establishmentId || resource.data.establishmentId);
    }
    
    match /professionals/{professionalId} {
      allow get, list: if true;
      allow write: if isSignedIn() && isMemberOf(request.resource.data.establishmentId || resource.data.establishmentId);
    }

    match /audit_logs/{logId} {
      allow create: if isSignedIn() && isMemberOf(request.resource.data.establishmentId);
      allow read: if isOwner(resource.data.establishmentId);
      allow update, delete: if false;
    }
    
    match /financial_natures/{docId} { allow read, write: if isSignedIn() && isMemberOf(request.resource.data.establishmentId || resource.data.establishmentId); }
    match /financial_cost_centers/{docId} { allow read, write: if isSignedIn() && isMemberOf(request.resource.data.establishmentId || resource.data.establishmentId); }
    match /financial_payables/{docId} { allow read, write: if isSignedIn() && isMemberOf(request.resource.data.establishmentId || resource.data.establishmentId); }
    match /financial_receivables/{docId} { allow read, write: if isSignedIn() && isMemberOf(request.resource.data.establishmentId || resource.data.establishmentId); }
  }
}